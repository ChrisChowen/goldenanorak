---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SubstackFeed from '../components/SubstackFeed.astro';
---

<BaseLayout title="Writing | Christopher Hogg" description="Published articles, essays, and Substack writing by Christopher Hogg on AI, creativity, and education.">

  <!-- Gradient Hero -->
  <section class="hero-gradient hero-gradient--writing grain relative">
    <div class="deco-dots top-10 right-10 absolute opacity-20"></div>
    <div class="container py-20 md:py-28">
      <p class="label text-gold mb-4 fade-in">Writing</p>
      <h1 class="heading-xl text-white mb-6 fade-in">Writing</h1>
      <p class="text-[#a09890] text-lg max-w-xl fade-in">Published articles on AI, creativity, education, and the human experience.</p>
    </div>
  </section>

  <!-- Published Articles — with colored accents per publication -->
  <section class="section-paper py-20 md:py-28">
    <div class="container">
      <div class="space-y-5 max-w-3xl stagger">
        <a href="https://www.timeshighereducation.com" target="_blank" rel="noopener noreferrer" class="card group block border-l-rathband fade-in">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="heading-sm group-hover:text-gold transition-colors">"What I learned when students walked out of my AI class"</h3>
            <span class="font-mono text-[0.68rem] text-fossil uppercase tracking-wider shrink-0">May 2025</span>
          </div>
          <p class="label mb-2" style="color: #8B1A1A;">Times Higher Education, Open Access</p>
          <p class="text-ash text-sm leading-relaxed">A widely-read article exploring what happened when students walked out of Christopher's AI class, and the lessons it taught about teaching, creativity, and resistance to technological change.</p>
        </a>

        <a href="https://www.timeshighereducation.com" target="_blank" rel="noopener noreferrer" class="card group block border-l-gold fade-in">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="heading-sm group-hover:text-gold transition-colors">"To demystify AI for your students, use performance"</h3>
            <span class="font-mono text-[0.68rem] text-fossil uppercase tracking-wider shrink-0">Oct 2024</span>
          </div>
          <p class="label text-gold mb-2">Times Higher Education, Open Access (co-authored with Will Shuler)</p>
          <p class="text-ash text-sm leading-relaxed">How performance-based teaching approaches can help students understand and engage with AI in ways that theory alone cannot achieve.</p>
        </a>

        <a href="https://wonkhe.com" target="_blank" rel="noopener noreferrer" class="card group block border-l-cassie fade-in">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="heading-sm group-hover:text-gold transition-colors">"What does authentic assessment mean in the context of AI?"</h3>
            <span class="font-mono text-[0.68rem] text-fossil uppercase tracking-wider shrink-0">2025</span>
          </div>
          <p class="label mb-2" style="color: #7B2D8B;">Wonkhe</p>
          <p class="text-ash text-sm leading-relaxed">Exploring the tension between authentic assessment and AI, and what it means for higher education.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Substack -->
  <section class="section-parchment py-20 md:py-28">
    <div class="container">
      <SectionHeader title="Latest from Substack" subtitle="Writing on AI, creativity, education, and memoir, published weekly." />

      <SubstackFeed />

      <div class="mt-12 text-center">
        <a href="https://christopherhogg.substack.com" target="_blank" rel="noopener noreferrer" class="btn btn-dark">
          Subscribe on Substack &rarr;
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
